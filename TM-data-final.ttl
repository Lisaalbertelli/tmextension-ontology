tm:topic_39 a tm:Topic;
rdfs:comment "A topic is a FrAC observation that groups observable lexical forms (OntoLex Forms) and is observed in a corpus."@en;
skos:prefLabel "Sardinian banditry"@en;
dct:description "This topic centers on the phenomenon of organized crime and banditry in Sardinia, including its social, legal, and political implications. It covers incidents involving bandits, law enforcement responses, mafia-related activities, and parliamentary discussions on policies, public safety, and justice concerning criminal activities in the region."@en;
skos:altLabel "Sardinian Banditry"@en,"Crime in Sardinia"@en,"Banditism and Mafia"@en,"Public Security Issues"@en .
